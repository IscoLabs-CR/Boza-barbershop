# ============================================================================
#  Variables de entorno — copiá este archivo a `.env.local` y ponelo en Vercel.
#
#  Arquitectura multitenant: TODOS los salones comparten UNA base de datos
#  (proyecto Supabase `isco-salones`), aislados por RLS. Por eso la URL, la anon
#  key y la clave VAPID pública son IGUALES para todos los clientes — lo único
#  que cambia por despliegue es el SLUG del salón.
# ============================================================================

# Base compartida (constante para todos los salones)
NEXT_PUBLIC_SUPABASE_URL=https://icwbzaronhvyicvfszvr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imljd2J6YXJvbmh2eWljdmZzenZyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMyODg1NjYsImV4cCI6MjA5ODg2NDU2Nn0.zAlgYqA1IopK5x1DNeavUOlP6YChAw4vIfuea93XhP0

# VAPID pública GLOBAL del SaaS (para suscribir push). La clave PRIVADA NO va acá:
# vive en app_config de la base compartida y solo la lee la Edge Function.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BN4z8ecbQ_QFYJhaqPlTINdhzmx33fh3o2NlnHmvd3dSkI-qLCP7cwi2uYenQLUvxzMCb3DdQ6inumRV27MTrcM

# >>> LO ÚNICO QUE CAMBIA POR CLIENTE <<< — el slug del salón en la base.
